      <repository-location id='Story1' path='/workbooks/uber_17811980603410' revision='' />
      <style>
        <style-rule element='story-point-caption'>
          <format attr='width' value='374' />
        </style-rule>
      </style>
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98120' id='1' param='vert' removable='false' type-v2='layout-flow' w='99034' x='483' y='940'>
            <zone h='4935' id='3' type-v2='title' w='99034' x='483' y='940' />
            <zone fixed-size='177' h='20799' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99034' x='483' y='5875' />
            <zone h='72386' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99034' x='483' y='26674'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption=' High Cancellations &amp; Long Wait Times Hurt Revenue&#10;Context: Cancellations by customers (6%) and drivers (7.5%) are significant, with waiting time data incomplete.&#10;Business relevance: Reducing wait times via better driver allocation could lower cancellations and recover lost booking value.' captured-sheet='Cancellation Trends' id='1' />
                  <story-point caption='Cash &amp; UPI Dominate Payments, but Digital Offers Upside&#10;Context: Cash (24.5k) and UPI (45.8k) lead booking value; cards and wallets trail.&#10;Business relevance: Promoting wallet/card incentives can reduce cash-handling costs and enable smoother post-ride digital engagement.' captured-sheet='Preffered Payment Method' id='2' />
                  <story-point caption='Auto &amp; Go Mini Generate Highest Booking Value&#10;Context: Auto (13.0M) and Go Mini (10.4M) lead vehicle types by booking value, while Bike (3.6M) lags. Go Sedan has he best rating&#10;Business relevance: Prioritizing marketing and driver incentives for high-value vehicle segments can maximize revenue per ride.&#10;&#10;' captured-sheet='Vehicle Type Versus Amount' id='3' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
      <simple-id uuid='{6B7738BD-A1A5-4240-B6E3-545F4D87359E}' />
    </dashboard>
